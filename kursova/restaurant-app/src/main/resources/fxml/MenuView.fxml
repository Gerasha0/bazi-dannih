<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<SplitPane dividerPositions="0.62" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.restaurant.ui.MenuController">

    <VBox spacing="0">
        <HBox styleClass="filter-bar" spacing="8" alignment="CENTER_LEFT">
            <Label text="Категорія" styleClass="field-label"/>
            <ComboBox fx:id="cbCategory" promptText="Всі" prefWidth="160" onAction="#handleFilter"/>
            <Label text="Доступність" styleClass="field-label"/>
            <ComboBox fx:id="cbAvailability" prefWidth="120" onAction="#handleFilter"/>
            <TextField fx:id="searchField" promptText="Пошук страви…" prefWidth="150"
                       onAction="#handleSearch" HBox.hgrow="ALWAYS"/>
            <Button text="🔍" styleClass="btn-primary" onAction="#handleSearch"/>
            <Button text="↺" styleClass="btn-refresh" onAction="#handleRefresh"/>
        </HBox>
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"       text="ID"        prefWidth="50"/>
                <TableColumn fx:id="colName"     text="Назва"     prefWidth="180"/>
                <TableColumn fx:id="colCategory" text="Категорія" prefWidth="120"/>
                <TableColumn fx:id="colPrice"    text="Ціна, грн" prefWidth="100"/>
                <TableColumn fx:id="colAvail"    text="Доступна"  prefWidth="80"/>
            </columns>
        </TableView>
        <HBox styleClass="action-bar" spacing="8">
            <Button text="➕ Додати"      styleClass="btn-success" onAction="#handleAdd"/>
            <Button text="🔀 Доступність" styleClass="btn-warning" onAction="#handleToggleAvailability"/>
            <Button text="🗑 Видалити"    styleClass="btn-danger"  onAction="#handleDelete"/>
        </HBox>
    </VBox>

    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
        <VBox spacing="10" styleClass="form-panel">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <Label text="Деталі страви" styleClass="section-title"/>

            <Label text="Назва *" styleClass="field-label"/>
            <TextField fx:id="fldName" promptText="Назва страви"/>

            <Label text="Категорія *" styleClass="field-label"/>
            <ComboBox fx:id="fldCategory" prefWidth="200"/>

            <Label text="Ціна (грн) *" styleClass="field-label"/>
            <TextField fx:id="fldPrice" promptText="0.00"/>

            <Label text="Опис" styleClass="field-label"/>
            <TextArea fx:id="fldDescription" prefRowCount="3" wrapText="true"/>

            <CheckBox fx:id="chkAvailable" text="Доступна в меню" selected="true"/>

            <HBox spacing="10">
                <Button text="💾 Зберегти"  styleClass="btn-primary"   onAction="#handleSave"   prefWidth="120"/>
                <Button text="✖ Скасувати" styleClass="btn-secondary" onAction="#handleCancel" prefWidth="100"/>
            </HBox>
            <Label fx:id="errorLabel" styleClass="error-label"/>
        </VBox>
    </ScrollPane>
</SplitPane>
