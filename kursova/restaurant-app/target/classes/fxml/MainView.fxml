<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.restaurant.ui.MainController"
            prefWidth="1260" prefHeight="800">

    <!-- ===== Sidebar ===== -->
    <left>
        <VBox styleClass="sidebar" prefWidth="200">

            <!-- Brand -->
            <VBox styleClass="sidebar-brand" alignment="CENTER" spacing="3">
                <padding><Insets top="26" right="12" bottom="22" left="12"/></padding>
                <Label text="🍽️" styleClass="brand-icon"/>
                <Label text="Restaurant" styleClass="brand-name"/>
                <Label text="MANAGER" styleClass="brand-sub"/>
            </VBox>

            <!-- Navigation -->
            <VBox VBox.vgrow="ALWAYS" spacing="2">
                <padding><Insets top="12" right="10" bottom="12" left="10"/></padding>
                <ToggleButton fx:id="btnRestaurants" text="🏠  Заклади"
                              styleClass="nav-btn" maxWidth="Infinity"/>
                <ToggleButton fx:id="btnMenu"        text="🍕  Меню"
                              styleClass="nav-btn" maxWidth="Infinity"/>
                <ToggleButton fx:id="btnOrders"      text="📋  Замовлення"
                              styleClass="nav-btn" maxWidth="Infinity"/>
                <ToggleButton fx:id="btnReservations" text="📅  Бронювання"
                              styleClass="nav-btn" maxWidth="Infinity"/>
                <ToggleButton fx:id="btnEmployees"   text="👔  Персонал"
                              styleClass="nav-btn" maxWidth="Infinity"/>
                <ToggleButton fx:id="btnCustomers"   text="👤  Клієнти"
                              styleClass="nav-btn" maxWidth="Infinity"/>
                <ToggleButton fx:id="btnReports"     text="📊  Звіти"
                              styleClass="nav-btn" maxWidth="Infinity"/>
            </VBox>

            <!-- Footer actions -->
            <VBox spacing="2">
                <padding><Insets top="8" right="10" bottom="22" left="10"/></padding>
                <Button text="ℹ  Про програму" styleClass="nav-footer-btn"
                        maxWidth="Infinity" onAction="#handleAbout"/>
                <Button text="✕  Вийти"        styleClass="nav-footer-btn"
                        maxWidth="Infinity" onAction="#handleExit"/>
            </VBox>
        </VBox>
    </left>

    <!-- ===== Main area ===== -->
    <center>
        <VBox styleClass="main-area">
            <!-- Top bar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>
                <Label fx:id="headerTitle" text="Заклади" styleClass="topbar-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusLabel" text="Готово" styleClass="status-chip"/>
            </HBox>
            <!-- Content pane — sections loaded dynamically -->
            <StackPane fx:id="contentPane" styleClass="content-pane" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
