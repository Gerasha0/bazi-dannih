<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<SplitPane dividerPositions="0.60" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.restaurant.ui.CustomersController">

    <VBox spacing="0">
        <HBox styleClass="filter-bar" spacing="8" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Прізвище, ім'я або телефон…" prefWidth="260"
                       onAction="#handleSearch" HBox.hgrow="ALWAYS"/>
            <Button text="🔍 Знайти"  styleClass="btn-primary"  onAction="#handleSearch"/>
            <Button text="↺ Оновити" styleClass="btn-refresh" onAction="#handleRefresh"/>
        </HBox>
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"     text="ID"      prefWidth="45"/>
                <TableColumn fx:id="colFull"   text="ПІБ"     prefWidth="180"/>
                <TableColumn fx:id="colPhone"  text="Телефон" prefWidth="130"/>
                <TableColumn fx:id="colEmail"  text="Email"   prefWidth="160"/>
                <TableColumn fx:id="colPoints" text="Бали"    prefWidth="70"/>
            </columns>
        </TableView>
        <HBox styleClass="action-bar" spacing="8">
            <Button text="➕ Додати"   styleClass="btn-success" onAction="#handleAdd"/>
            <Button text="🗑 Видалити" styleClass="btn-danger"  onAction="#handleDelete"/>
        </HBox>
    </VBox>

    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
        <VBox spacing="10" styleClass="form-panel">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <Label text="Дані клієнта" styleClass="section-title"/>

            <HBox spacing="12">
                <VBox HBox.hgrow="ALWAYS" spacing="4">
                    <Label text="Ім'я *" styleClass="field-label"/>
                    <TextField fx:id="fldFirstName" promptText="Ім'я"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="4">
                    <Label text="Прізвище *" styleClass="field-label"/>
                    <TextField fx:id="fldLastName" promptText="Прізвище"/>
                </VBox>
            </HBox>

            <Label text="Телефон" styleClass="field-label"/>
            <TextField fx:id="fldPhone" promptText="+380XXXXXXXXX"/>

            <Label text="Email" styleClass="field-label"/>
            <TextField fx:id="fldEmail" promptText="email@example.com"/>

            <Label text="Бонусні бали" styleClass="field-label"/>
            <TextField fx:id="fldPoints" promptText="0" editable="false"/>

            <HBox spacing="10">
                <Button text="💾 Зберегти"  styleClass="btn-primary"   onAction="#handleSave"   prefWidth="120"/>
                <Button text="✖ Скасувати" styleClass="btn-secondary" onAction="#handleCancel" prefWidth="100"/>
            </HBox>
            <Label fx:id="errorLabel" styleClass="error-label"/>
        </VBox>
    </ScrollPane>
</SplitPane>
